# This is a TEMPLATE only — do not put real keys in this file, and never
# commit a real secrets.toml to GitHub (it's already in .gitignore).
#
# For LOCAL development: copy this to .streamlit/secrets.toml and fill in
# real values, OR just export environment variables instead — config.py
# supports both.
#
# For STREAMLIT COMMUNITY CLOUD: paste the contents (with real values)
# into your app's "Settings -> Secrets" panel in the Streamlit Cloud
# dashboard. You do NOT need to commit this file for that to work.

LLM_PROVIDER = "gemini"          # "none", "openai", "anthropic", or "gemini"
GEMINI_API_KEY = "your_key_here"
GEMINI_MODEL = "gemini-2.0-flash"

# OPENAI_API_KEY = "sk-..."
# OPENAI_MODEL = "gpt-4o-mini"

# ANTHROPIC_API_KEY = "sk-ant-..."
# ANTHROPIC_MODEL = "claude-3-5-sonnet-latest"

# TAVILY_API_KEY = "tvly-..."
ENABLE_WEB_SEARCH = "true"

# Only needed if your .pkl files aren't at the default paths below
# DISEASE_MODEL_PATH = "models/disease_model.pkl"
# MEDICINE_MODEL_PATH = "models/madicine_suggestion.pkl"
